    "Your feedback matters! Please consider rating us. Your support helps us improve.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din feedback er vigtig! Overvej venligst at bedømme os. Din støtte hjælper os med at forbedre os."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Feedback ist uns wichtig! Bitte bewerten Sie uns. Ihre Unterstützung hilft uns, uns zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your feedback matters! Please consider rating us. Your support helps us improve."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre avis compte ! N'hésitez pas à nous évaluer. Votre soutien nous aide à nous améliorer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo feedback è importante! Considera di darci una valutazione. Il tuo supporto ci aiuta a migliorare."
          }
        }
      }
