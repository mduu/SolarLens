    "To let Solar Manager control the battery disable 'Allow standalone'.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "For at lade Solar Manager styre batteriet skal du deaktivere 'Tillad selvstændig drift'."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um dem Solar Manager die Kontrolle über die Batterie zu überlassen, deaktivieren Sie 'Eigenständigen Betrieb erlauben'."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
