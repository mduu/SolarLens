    "Reaches a target battery percentage by a time you set. Prefers solar power when available and tops up from the grid if needed.": {
      "comment": "Description of a charging mode called \"chargingTargetSoc\".",
      "isCommentAutoGenerated": true,
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når en ønsket batteriprocent inden et tidspunkt, du vælger. Foretrækker solenergi og supplerer fra elnettet om nødvendigt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
