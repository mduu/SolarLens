    "Battery will be charged to the 'Morning' level in the morning. Then other devices can be charged. The battery will be charged to 'Max' until the eventing.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Batteriet oplades til 'Morgen'-niveauet om morgenen. Derefter kan andre enheder oplades. Batteriet oplades til 'Max' indtil aften."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Batterie wird morgens bis zum Niveau 'Morgen' geladen. Danach können andere Geräte geladen werden. Bis zum Abend wird die Batterie auf 'Max' geladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery will be charged to the 'Morning' level in the morning. Then other devices can be charged. The battery will be charged to 'Max' until the eventing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La batterie sera chargée au niveau 'Matin' le matin. Ensuite, d'autres appareils pourront être chargés. La batterie sera chargée au 'Max' jusqu'au soir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La batteria verrà caricata al livello 'Mattina' al mattino. Successivamente, altri dispositivi potranno essere caricati. La batteria verrà caricata al 'Max' fino a sera."
          }
        }
      }
    },
