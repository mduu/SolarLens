    "We'll stop a few % earlier when iOS is throttling background updates so the battery stays above your floor when possible." : {
      "comment" : "A description of the battery level slider.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi stopper et par % tidligere, når iOS begrænser baggrundsopdateringer, så batteriet bliver over dit minimum, når det er muligt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir stoppen ein paar % früher, wenn iOS Hintergrund-Updates drosselt, damit die Batterie wenn möglich über deinem Mindeststand bleibt."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous arrêterons quelques % plus tôt si iOS limite les mises à jour en arrière-plan, afin que la batterie reste au-dessus de votre seuil lorsque c'est possible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ci fermeremo qualche % prima quando iOS limita gli aggiornamenti in background, in modo che la batteria rimanga sopra il tuo minimo quando possibile."
          }
        }
