    "Get a notification when battery, solar, grid or charging crosses a level you choose. Run several in parallel." : {
      "comment" : "A description of the functionality of the notification feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Få en notifikation, når batteri, sol, elnet eller opladning krydser et niveau, du vælger. Kør flere parallelt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalte eine Benachrichtigung, wenn Batterie, Solar, Netz oder Laden einen von dir gewählten Wert über- oder unterschreitet. Mehrere können parallel laufen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reçois une notification lorsque la batterie, le solaire, le réseau ou la charge franchit un niveau de ton choix. Lance-en plusieurs en parallèle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ricevi una notifica quando batteria, solare, rete o ricarica attraversa un livello a tua scelta. Puoi eseguirne diverse in parallelo."
          }
        }
      }
    },
    "Get a push notification when your house battery reaches a level you choose. Auto-cancels after 24 hours if the level isn't reached." : {
      "comment" : "A description of the Notify on battery level automation.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Få en push-notifikation, når dit husbatteri når et niveau, du vælger. Annulleres automatisk efter 24 timer, hvis niveauet ikke nås."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalte eine Push-Benachrichtigung, wenn deine Haus-Batterie den von dir gewählten Stand erreicht. Bricht nach 24 Stunden automatisch ab, wenn der Stand nicht erreicht wird."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reçois une notification push lorsque ta batterie maison atteint le niveau que tu choisis. S’annule automatiquement après 24 heures si le niveau n’est pas atteint."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ricevi una notifica push quando la tua batteria di casa raggiunge il livello che scegli. Si annulla automaticamente dopo 24 ore se il livello non viene raggiunto."
          }
        }
      }
    },
