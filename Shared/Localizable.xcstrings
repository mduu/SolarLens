    "'Peak Shaving' uses your battery to supply power during high-demand periods, reducing the amount of expensive electricity drawn from the grid and lowering your overall costs.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "'Peak Shaving' bruger dit batteri til at levere strøm i perioder med høj efterspørgsel, hvilket reducerer mængden af dyr elektricitet trukket fra nettet og sænker dine samlede omkostninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "'Peak Shaving' nutzt Ihre Batterie, um während Perioden hoher Nachfrage Strom zu liefern, wodurch die Menge an teurem Strom aus dem Netz reduziert und Ihre Gesamtkosten gesenkt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "'Peak Shaving' uses your battery to supply power during high-demand periods, reducing the amount of expensive electricity drawn from the grid and lowering your overall costs."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le 'Peak Shaving' utilise votre batterie pour fournir de l'énergie pendant les périodes de forte demande, réduisant ainsi la quantité d'électricité coûteuse tirée du réseau et diminuant vos coûts globaux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il 'Peak Shaving' utilizza la batteria per fornire energia durante i periodi di alta domanda, riducendo la quantità di elettricità costosa prelevata dalla rete e abbassando i costi complessivi."
          }
        }
      }
    },
