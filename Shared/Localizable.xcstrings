            "value": "Il livello della batteria della nostra casa è a %lld%%"
          }
        }
      }
    },
    "The battery will operate in standalone mode (if a smart meter is present) or controlled by Solar Manager with min/max percentage settings.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Batteriet vil fungere i selvstændig tilstand (hvis en smart meter er til stede) eller styret af Solar Manager med min/maks procentindstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Batterie arbeitet im eigenständigen Modus (falls ein Smart Meter vorhanden ist) oder wird vom Solar Manager mit Min/Max-Prozentsatzeinstellungen gesteuert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The battery will operate in standalone mode (if a smart meter is present) or controlled by Solar Manager with min/max percentage settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La batterie fonctionnera en mode autonome (si un compteur intelligent est présent) ou sera contrôlée par Solar Manager avec des réglages de pourcentage min/max."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La batteria opererà in modalità autonoma (se è presente un contatore intelligente) o sarà controllata da Solar Manager con impostazioni di percentuale min/max."
          }
        }
      }
    },
