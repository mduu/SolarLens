          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Atteint un pourcentage de batterie cible à l'heure que vous définissez. Privilégie l'énergie solaire et complète depuis le réseau si nécessaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Raggiunge una percentuale di batteria target entro un orario impostato. Preferisce l'energia solare e integra dalla rete se necessario."
