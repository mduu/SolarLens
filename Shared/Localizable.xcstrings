    "SurveyGreeingWatchOs": {
      "comment": "A message presented in a survey on the Apple Watch, inviting the user to fill it out.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hej! Jeg er Marc, udvikleren af Solar Lens. Jeg planlægger de næste funktioner lige nu og vil meget gerne høre din mening. Har du 3 minutter til et hurtigt spørgeskema? Din feedback hjælper mig med at gøre appen endnu bedre for dig ☀️\n\nTak for din støtte! — Marc"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! Ich bin Marc, der Entwickler von Solar Lens. Ich plane gerade die nächsten Funktionen und würde mich riesig über dein Feedback freuen. Hast du 3 Minuten Zeit für eine kurze Umfrage? Deine Meinung hilft mir, die App noch besser für dich zu machen ☀️\n\nDanke für deine Unterstützung! — Marc"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Greeting from the developer! As I am thinking about the next features of Solar Lens I am very interested in your feedback. It would be very kind if you fill out the survey which takes less then 5 minutes. Please open the iOS app and continue there.\nGreeting, Marc"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Salut ! Je suis Marc, le développeur de Solar Lens. Je prépare actuellement les prochaines fonctionnalités et ton avis m'intéresse beaucoup. Aurais-tu 3 minutes pour un court sondage ? Tes retours m'aident à améliorer l'application pour toi ☀️\n\nMerci pour ton soutien ! — Marc"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciao! Sono Marc, lo sviluppatore di Solar Lens. Sto pianificando le prossime funzioni e mi piacerebbe molto avere il tuo parere. Avresti 3 minuti per un breve sondaggio? Il tuo feedback mi aiuta a migliorare l'app per te ☀️\n\nGrazie per il tuo supporto! — Marc"
          }
        }
      }
    },
    "SurveyGreetingIOS\nThanks for your support! — Marc": {
      "comment": "A message presented in the survey, inviting the user to participate.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hej! Jeg er Marc, udvikleren af Solar Lens. Jeg planlægger de næste funktioner lige nu og vil meget gerne høre din mening. Har du 3 minutter til et hurtigt spørgeskema? Din feedback hjælper mig med at gøre appen endnu bedre for dig ☀️\n\nTak for din støtte! — Marc"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! Ich bin Marc, der Entwickler von Solar Lens. Ich plane gerade die nächsten Funktionen und würde mich riesig über dein Feedback freuen. Hast du 3 Minuten Zeit für eine kurze Umfrage? Deine Meinung hilft mir, die App noch besser für dich zu machen ☀️\n\nDanke für deine Unterstützung! — Marc"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I’m Marc, the developer of Solar Lens. I’m currently planning the next features and would love your input. Could you spare 3 minutes for a quick survey? Your feedback helps me build a better app for you ☀️\n\nThanks for your support! — Marc"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Salut ! Je suis Marc, le développeur de Solar Lens. Je prépare actuellement les prochaines fonctionnalités et ton avis m'intéresse beaucoup. Aurais-tu 3 minutes pour un court sondage ? Tes retours m'aident à améliorer l'application pour toi ☀️\n\nMerci pour ton soutien ! — Marc"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciao! Sono Marc, lo sviluppatore di Solar Lens. Sto pianificando le prossime funzioni e mi piacerebbe molto avere il tuo parere. Avresti 3 minuti per un breve sondaggio? Il tuo feedback mi aiuta a migliorare l'app per te ☀️\n\nGrazie per il tuo supporto! — Marc"
          }
        }
      }
    },
